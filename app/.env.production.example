# app/.env.production.example — @ansem/app mainnet (Phase 0) config template.
#
# Copy to `.env.production` (or set these in the Vercel project's env) and fill
# every placeholder. NEVER commit a real RPC/API key — the values below are
# placeholders. Only the NEXT_PUBLIC_* names below are read by the app; grep
# `process.env.NEXT_PUBLIC` under app/src to confirm the full set.

# --- Solana RPC + cluster (src/components/Providers.tsx, src/lib/explorer.ts) ---
# Helius mainnet endpoint. Replace YOUR_KEY with your Helius API key.
NEXT_PUBLIC_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Wallet-adapter + explorer cluster. Drives the explorer link suffix too.
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# --- Keeper read-layer (src/app/page.tsx -> src/lib/keeper-client.ts) ---
# The Railway-hosted keeper read server. Use wss:// + https:// in production (TLS).
NEXT_PUBLIC_KEEPER_WS=wss://<keeper-host>.up.railway.app
NEXT_PUBLIC_KEEPER_HTTP=https://<keeper-host>.up.railway.app

# --- MagicBlock Ephemeral Rollup (src/lib/anchor.ts; gasless session writes) ---
# Mainnet ER endpoints. Leave unset to fall back to the SDK's devnet defaults
# (https/wss://devnet-us.magicblock.app) — set the mainnet host before launch.
NEXT_PUBLIC_ER_ENDPOINT=https://<mainnet-er-host>.magicblock.app
NEXT_PUBLIC_ER_WS_ENDPOINT=wss://<mainnet-er-host>.magicblock.app

# --- Reference values (NOT read from env today; recorded for the launch runbook) ---
# Program ID is compiled into @ansem/sdk (packages/sdk/src/constants.ts PROGRAM_ID);
# it is not an env var. Mainnet deployment target:
#   PROGRAM_ID=8Q9EnK7ydn6ywo7ZxeqhubqYybf7FFNNwnz8JzJjXZjz
# Explorer base: src/lib/explorer.ts currently builds explorer.solana.com links.
# Solscan mainnet base, for reference / a future switch:
#   https://solscan.io
